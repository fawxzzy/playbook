{
  "schemaVersion": "1.0",
  "command": "ai-context",
  "repo": {
    "summary": "Playbook is an AI-aware engineering governance CLI with deterministic command contracts.",
    "architecture": "modular-monolith",
    "localCliPreferred": true
  },
  "repositoryIntelligence": {
    "artifact": ".playbook/repo-index.json",
    "moduleDigestsArtifact": ".playbook/module-digests.json",
    "moduleDigestsAvailable": true,
    "moduleDigestCount": 1,
    "available": true,
    "commands": [
      "index",
      "query",
      "deps",
      "ask",
      "explain"
    ]
  },
  "controlPlaneArtifacts": {
    "policyEvaluation": ".playbook/policy-evaluation.json",
    "policyApplyResult": ".playbook/policy-apply-result.json",
    "session": ".playbook/session.json",
    "cycleState": ".playbook/cycle-state.json",
    "cycleHistory": ".playbook/cycle-history.json",
    "improvementCandidates": ".playbook/improvement-candidates.json",
    "prReview": ".playbook/pr-review.json"
  },
  "runtimeManifests": {
    "artifact": ".playbook/runtime-manifests.json",
    "manifestsCount": 0,
    "manifests": []
  },
  "continuity": {
    "doctrine": {
      "role": "core_continuity_doctrine",
      "path": "docs/contracts/PLAYBOOK-CONTRACT.md",
      "export_path": "exports/playbook.contract.example.v1.json",
      "registration_state": "registered"
    }
  },
  "operatingLadder": {
    "preferredCommandOrder": [
      "ai-context",
      "ai-contract",
      "context",
      "index",
      "query",
      "explain",
      "ask --repo-context",
      "rules",
      "verify",
      "direct-file-inspection-if-needed"
    ],
    "recommendedBootstrap": [
      "pnpm -r build",
      "node packages/cli/dist/main.js ai-context --json",
      "node packages/cli/dist/main.js context --json"
    ],
    "remediationWorkflow": [
      "verify",
      "explain",
      "plan",
      "apply",
      "verify"
    ]
  },
  "productCommands": [
    {
      "name": "verify",
      "example": "playbook verify --json"
    },
    {
      "name": "plan",
      "example": "playbook plan --json"
    },
    {
      "name": "apply",
      "example": "playbook apply --from-plan .playbook/plan.json"
    },
    {
      "name": "explain",
      "example": "playbook explain architecture --json"
    },
    {
      "name": "context",
      "example": "playbook context --json"
    },
    {
      "name": "ai-context",
      "example": "playbook ai-context --json"
    },
    {
      "name": "ai-contract",
      "example": "playbook ai-contract"
    },
    {
      "name": "index",
      "example": "playbook index --json"
    },
    {
      "name": "ask",
      "example": "playbook ask \"where should a new feature live?\" --repo-context --json"
    },
    {
      "name": "query",
      "example": "playbook query modules --json"
    }
  ],
  "riskAwareContext": {
    "artifact": ".playbook/module-digests.json",
    "shapedAtDeterministic": true,
    "modulesConsidered": 1,
    "highRiskModules": 0,
    "lowRiskModules": 1,
    "defaultDepthByTier": {
      "high": "rich",
      "low": "concise"
    },
    "provenanceRefs": [
      ".playbook/module-digests.json",
      ".playbook/repo-graph.json",
      ".playbook/repo-index.json"
    ],
    "modules": [
      {
        "module": "features",
        "shapedRiskTier": "low",
        "contextDepth": "concise",
        "rationale": "Lower risk profile keeps module context concise for token-efficient reasoning.",
        "provenanceRefs": [
          ".playbook/module-digests.json",
          ".playbook/repo-graph.json",
          ".playbook/repo-index.json"
        ],
        "context": {
          "summary": "Module features encapsulates bounded repository behavior with graph neighborhood out[governed_by], in[contains].",
          "dependencies": [],
          "dependents": {
            "direct": [],
            "transitive": []
          },
          "risk": {
            "level": "low",
            "score": 0,
            "signals": [
              "Low fan-in and limited transitive impact",
              "warning: Verify failure signal unavailable; no .playbook/verify-report.json, .playbook/verify.json, .playbook/findings.json, or .playbook/plan.json verify payload found."
            ]
          }
        }
      }
    ]
  },
  "guidance": {
    "preferPlaybookCommands": true,
    "authorityRule": "Playbook command outputs are authoritative over ad-hoc repository inference when command coverage exists.",
    "localExecutionRule": "Inside the Playbook repository, use local built CLI entrypoints for branch-accurate validation.",
    "failureMode": "Agent drift occurs when AI tools bypass Playbook command outputs and reason directly from stale or incomplete file inspection.",
    "memoryCommandFamily": {
      "available": true,
      "preferredCommands": [
        "memory events --json",
        "memory knowledge --json",
        "memory candidates --json"
      ]
    },
    "promotedKnowledgeGuidance": "Prefer promoted knowledge for retrieval and planning support because it is reviewed and stable doctrine.",
    "candidateKnowledgeGuidance": "Treat candidates as advisory-only signals until reviewed promotion; never treat candidate artifacts as authoritative doctrine."
  }
}

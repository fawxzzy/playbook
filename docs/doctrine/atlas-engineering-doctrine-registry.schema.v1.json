{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas-engineering-doctrine-registry.schema.v1.json",
  "title": "Atlas Engineering Doctrine Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "owner", "consumer_adoption", "records"],
  "properties": {
    "schema_version": { "const": "atlas-engineering-doctrine-registry.v1" },
    "registry_id": { "const": "atlas-engineering-doctrine-registry" },
    "owner": { "const": "playbook" },
    "consumer_adoption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atlas_role", "discovery", "copying_rule"],
      "properties": {
        "atlas_role": { "const": "adopter-and-conformance-owner" },
        "discovery": { "type": "string", "minLength": 1 },
        "copying_rule": { "type": "string", "minLength": 1 }
      }
    },
    "records": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/record" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "authority", "ref", "note"],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/id" },
        "authority": { "enum": ["canonical-playbook", "canonical-atlas", "imported-provenance"] },
        "ref": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "lifecycle", "statement", "rationale", "scope", "evidence", "enforcement", "exceptions", "review", "supersession"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["rule", "pattern", "failure-mode", "decision"] },
        "lifecycle": { "enum": ["candidate", "promoted", "retired", "superseded"] },
        "statement": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["truth_class", "applies_to", "excludes"],
          "properties": {
            "truth_class": { "enum": ["universal-doctrine", "repo-local-instruction", "runtime-state", "board-card-state", "imported-provenance"] },
            "applies_to": { "type": "string", "minLength": 1 },
            "excludes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          }
        },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
        "enforcement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "mechanism"],
          "properties": { "owner": { "type": "string", "minLength": 1 }, "mechanism": { "type": "string", "minLength": 1 } }
        },
        "exceptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["last_reviewed", "reviewer", "next_review_due"],
          "properties": { "last_reviewed": { "type": "string", "format": "date" }, "reviewer": { "type": "string", "minLength": 1 }, "next_review_due": { "type": "string", "format": "date" } }
        },
        "supersession": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supersedes", "superseded_by", "retired_reason"],
          "properties": { "supersedes": { "type": "array", "items": { "$ref": "#/$defs/id" } }, "superseded_by": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" }, "retired_reason": { "type": ["string", "null"] } }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawxzzy.dev/schemas/playbook.repo-scorecard.v1.json",
  "title": "Playbook Repo Scorecard v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "repo",
    "overallStatus",
    "summary",
    "dimensions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "playbook.repo-scorecard.v1"
    },
    "repo": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "overallStatus": {
      "enum": [
        "verified",
        "partial",
        "missing",
        "not_applicable"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "verified",
        "partial",
        "missing",
        "notApplicable"
      ],
      "properties": {
        "verified": {
          "type": "integer",
          "minimum": 0
        },
        "partial": {
          "type": "integer",
          "minimum": 0
        },
        "missing": {
          "type": "integer",
          "minimum": 0
        },
        "notApplicable": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "dimensions": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "summary",
          "evidence"
        ],
        "properties": {
          "id": {
            "enum": [
              "owner_truth",
              "command_truth",
              "verification_truth",
              "artifact_hygiene",
              "docs_governance",
              "workflow_pack_adoption",
              "local_verification",
              "roadmap_governance"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "verified",
              "partial",
              "missing",
              "not_applicable"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "contractRoles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "core_continuity_doctrine"
              ]
            }
          },
          "contractExportPaths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "nextAction": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
